package gui

import "core:log"
import "core:mem"

// Simple bitmap font for GUI rendering
// Uses a monospace font layout for simplicity

FONT_CHAR_WIDTH :: 8
FONT_CHAR_HEIGHT :: 16
FONT_ATLAS_WIDTH :: 128  // 16 chars per row
FONT_ATLAS_HEIGHT :: 128 // 8 rows
FONT_FIRST_CHAR :: 32   // Space character
FONT_LAST_CHAR :: 127   // DEL character
FONT_CHAR_COUNT :: FONT_LAST_CHAR - FONT_FIRST_CHAR + 1

