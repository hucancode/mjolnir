// Generate font atlas texture from bitmap data
generate_font_atlas :: proc(allocator := context.allocator) -> []u8 {
    atlas_size := FONT_ATLAS_WIDTH * FONT_ATLAS_HEIGHT
    pixels := make([]u8, atlas_size, allocator)
    
    // Clear atlas
    mem.set(raw_data(pixels), 0, atlas_size)
    
    // Render each character to the atlas
    for char_idx in 0..<FONT_CHAR_COUNT {
        // Calculate position in atlas (16 chars per row)
        atlas_x := (char_idx % 16) * FONT_CHAR_WIDTH
        atlas_y := (char_idx / 16) * FONT_CHAR_HEIGHT
        
        // Copy character bitmap to atlas
        char_data := &default_font_data[char_idx]
        for y in 0..<FONT_CHAR_HEIGHT {
            for x in 0..<FONT_CHAR_WIDTH {
                // Extract bit from byte
                byte_val := char_data[y]
                bit := (byte_val >> u8(7 - x)) & 1
                
                // Set pixel in atlas
                atlas_idx := (atlas_y + y) * FONT_ATLAS_WIDTH + (atlas_x + x)
                pixels[atlas_idx] = bit * 255
            }
        }
    }
    
    return pixels
}

// Get UV coordinates for a character in the atlas
get_char_uv :: proc(char: u8) -> [4]f32 {
    c := char
    if c < FONT_FIRST_CHAR || c > FONT_LAST_CHAR {
        c = u8('?') // Use ? for unknown characters
    }
    
    char_idx := int(c - FONT_FIRST_CHAR)
    atlas_x := f32((char_idx % 16) * FONT_CHAR_WIDTH)
    atlas_y := f32((char_idx / 16) * FONT_CHAR_HEIGHT)
    
    return {
        atlas_x / f32(FONT_ATLAS_WIDTH),
        atlas_y / f32(FONT_ATLAS_HEIGHT),
        (atlas_x + f32(FONT_CHAR_WIDTH)) / f32(FONT_ATLAS_WIDTH),
        (atlas_y + f32(FONT_CHAR_HEIGHT)) / f32(FONT_ATLAS_HEIGHT),
    }
}

// Calculate text dimensions
measure_text :: proc(text: string, scale: f32 = 1.0) -> [2]f32 {
    width := f32(len(text)) * f32(FONT_CHAR_WIDTH) * scale
    height := f32(FONT_CHAR_HEIGHT) * scale
    return {width, height}
}